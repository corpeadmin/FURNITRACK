@model FURNITRACK.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 100vh; background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
    <div class="card shadow-sm border-0" style="width: 100%; max-width: 420px; border-radius: 12px;">
        <div class="card-body p-5">

            <div class="text-center mb-5">
                <div class="mb-3">
                    <i class="bi bi-box-seam" style="font-size: 3rem; color: #1a335d;"></i>
                </div>
                <h3 class="fw-bold mb-1" style="color: #1a335d; letter-spacing: 1px;">FURNITRACK</h3>
                <p class="text-muted small uppercase">Ken's Marketing & General Merchandise</p>
            </div>

            <form asp-action="Login" method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label small fw-bold text-secondary">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted">
                            <i class="bi bi-envelope"></i>
                        </span>
                        <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="e.g. admin@furnitrack.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label small fw-bold text-secondary">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted">
                            <i class="bi bi-lock"></i>
                        </span>
                        <input asp-for="Password" class="form-control border-start-0 ps-0" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 d-flex justify-content-between">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label small text-muted">Remember me</label>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary py-2 fw-bold" style="background-color: #1a335d; border: none; border-radius: 6px;">
                        Login to Dashboard
                    </button>
                </div>

                <div class="mt-4 text-center">
                    <div class="alert alert-info py-2 px-3 small" style="font-size: 0.75rem;">
                        <strong>Demo Access:</strong><br />
                        Email: john.doe@furnitrack.com<br />
                        Pass: Password123
                    </div>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}