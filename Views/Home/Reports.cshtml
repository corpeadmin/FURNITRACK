@model FURNITRACK.ViewModels.ReportsViewModel
@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="reports-container">
    @* HEADER SECTION *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: #1e293b;">Reports & Analytics</h2>
            <p class="text-muted">Track sales performance and inventory metrics</p>
        </div>

        @* DATE FILTER *@
        <div class="d-flex align-items-center bg-white border rounded-3 px-3 py-1 shadow-sm" style="border-color: #e2e8f0 !important;">
            <i class="bi bi-calendar3 text-muted me-2"></i>
            <span class="text-muted small fw-medium">@Model.StartDate.ToString("MMM dd") - @Model.EndDate.ToString("MMM dd, yyyy")</span>
        </div>
    </div>

    @* SUMMARY CARDS *@
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border shadow-sm p-3 h-100 border-light">
                <div class="d-flex align-items-center">
                    <div class="rounded-3 p-3 me-3" style="background-color: #f1f5f9;">
                        <i class="bi bi-currency-dollar fs-4" style="color: #475569;"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block fw-medium">Total Revenue</small>
                        <h4 class="fw-bold mb-0">@Model.TotalSales.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border shadow-sm p-3 h-100 border-light">
                <div class="d-flex align-items-center">
                    <div class="rounded-3 p-3 me-3" style="background-color: #f0fdf4;">
                        <i class="bi bi-cart-check fs-4" style="color: #22c55e;"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block fw-medium">Orders Placed</small>
                        <h4 class="fw-bold mb-0">@Model.TotalOrders</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border shadow-sm p-3 h-100 border-light">
                <div class="d-flex align-items-center">
                    <div class="rounded-3 p-3 me-3" style="background-color: #fffbeb;">
                        <i class="bi bi-bag-check fs-4" style="color: #f59e0b;"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block fw-medium">Avg. Order Value</small>
                        <h4 class="fw-bold mb-0">@Model.AverageOrderValue.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border shadow-sm p-3 h-100 border-light">
                <div class="d-flex align-items-center">
                    <div class="rounded-3 p-3 me-3" style="background-color: #f1f5f9;">
                        <i class="bi bi-box-seam fs-4" style="color: #475569;"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block fw-medium">Inventory Value</small>
                        <h4 class="fw-bold mb-0">@Model.TotalInventoryValue.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* INVENTORY METRICS *@
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card border shadow-sm h-100 border-light">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="fw-bold mb-0">Inventory Health</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Total Products</span>
                        <span class="fw-bold">@Model.TotalProducts</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Low Stock Items</span>
                        <span class="fw-bold text-danger">@Model.LowStockItems</span>
                    </div>
                    <div class="progress mt-3" style="height: 10px;">
                        @{
                            double healthyPercent = Model.TotalProducts > 0 ? ((double)(Model.TotalProducts - Model.LowStockItems) / Model.TotalProducts) * 100 : 0;
                        }
                        <div class="progress-bar bg-success" role="progressbar" style="width: @healthyPercent%" aria-valuenow="@healthyPercent" aria-valuemin="0" aria-valuemax="100"></div>
                        <div class="progress-bar bg-danger" role="progressbar" style="width: @(100 - healthyPercent)%" aria-valuenow="@(100 - healthyPercent)" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div class="d-flex justify-content-between mt-2 small text-muted">
                        <span>Healthy (@((int)healthyPercent)%)</span>
                        <span>Low Stock (@(100 - (int)healthyPercent)%)</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border shadow-sm h-100 border-light">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="fw-bold mb-0">Sales Performance</h5>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <div class="text-center">
                        <i class="bi bi-pie-chart fs-1 text-muted mb-3 d-block"></i>
                        <p class="text-muted">Graphical analytics will be integrated with Chart.js in the next phase.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .reports-container {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    .card {
        border-radius: 10px;
    }

    .table thead th {
        font-size: 0.75rem;
        letter-spacing: 0.05rem;
    }

    .table tbody td {
        padding-top: 1.25rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        font-size: 0.95rem;
    }

    .badge {
        font-weight: 600;
        font-size: 0.8rem;
    }
</style>