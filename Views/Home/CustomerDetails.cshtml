@model FURNITRACK.ViewModels.CustomersViewModel
@{
    ViewData["Title"] = "Customer History";
}

<div class="mb-4 d-flex align-items-center">
    <a asp-action="Customers" class="btn btn-sm glass-card border-0 me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h2 class="fw-bold mb-0">@Model.SelectedCustomer?.Name</h2>
        <p class="text-muted mb-0">Purchase history and account details</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card glass-card p-4">
            <h5 class="fw-bold mb-4">Customer Info</h5>
            <div class="mb-3">
                <label class="small text-muted text-uppercase fw-bold">Full Name</label>
                <p class="mb-0 fw-medium">@Model.SelectedCustomer?.Name</p>
            </div>
            <div class="mb-3">
                <label class="small text-muted text-uppercase fw-bold">Email Address</label>
                <p class="mb-0 fw-medium">@(Model.SelectedCustomer?.Email ?? "No email provided")</p>
            </div>
            <div class="mb-3">
                <label class="small text-muted text-uppercase fw-bold">Phone Number</label>
                <p class="mb-0 fw-medium">@(Model.SelectedCustomer?.Phone ?? "No phone provided")</p>
            </div>
            <div class="mb-3">
                <label class="small text-muted text-uppercase fw-bold">Address</label>
                <p class="mb-0 fw-medium">@(Model.SelectedCustomer?.Address ?? "No address recorded")</p>
            </div>
            <hr class="my-4 border-white border-opacity-10">
            <div class="mb-1">
                <label class="small text-muted text-uppercase fw-bold">Customer Since</label>
                <p class="mb-0">@Model.SelectedCustomer?.CreatedDate.ToString("MMMM dd, yyyy")</p>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card glass-card">
            <div class="card-header bg-transparent py-3 border-0">
                <h5 class="fw-bold mb-0">Purchase History</h5>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="text-muted">
                        <tr>
                            <th class="ps-4">Date</th>
                            <th>Order #</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.PurchaseHistory.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <p class="text-muted mb-0">No purchase records found for this customer.</p>
                                </td>
                            </tr>
                        }
                        @foreach (var sale in Model.PurchaseHistory)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">@sale.SalesDate.ToString("MMM dd, yyyy")</td>
                                <td class="fw-bold">@sale.OrderNumber</td>
                                <td>
                                    @foreach (var item in sale.SalesItems)
                                    {
                                        <div class="small">@(item.Product?.Name ?? "Product") (x@item.Quantity)</div>
                                    }
                                </td>
                                <td class="fw-bold text-success">@sale.TotalAmount.ToString("C", new System.Globalization.CultureInfo("en-PH"))</td>
                                <td>
                                    <span class="badge bg-success-subtle text-success border border-success border-opacity-25 px-3 rounded-pill">@sale.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
