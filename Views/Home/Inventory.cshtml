@model FURNITRACK.ViewModels.InventoryViewModel
@{
    ViewData["Title"] = "Inventory Management";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <h2 class="fw-bold mb-0">Inventory Management</h2>
        <p class="text-muted">Manage your furniture stock and pricing</p>
    </div>

    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <button class="btn text-white px-4 py-2 fw-bold shadow-sm"
                style="background-color: #1a335d;"
                data-bs-toggle="modal"
                data-bs-target="#addItemModal">
            <i class="bi bi-plus-lg me-2"></i> Add Item
        </button>
    }
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3">
            <p class="text-muted small mb-1">Total Products</p>
            <h4 class="fw-bold mb-0">@Model.TotalProducts</h4>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3">
            <p class="text-muted small mb-1">Total Inventory Value</p>
            <h4 class="fw-bold mb-0">@Model.TotalInventoryValue.ToString("C", new System.Globalization.CultureInfo("en-PH"))</h4>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3">
            <p class="text-muted small mb-1">Low Stock Items</p>
            <h4 class="fw-bold mb-0 text-danger">@Model.LowStockCount</h4>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <div class="input-group">
            <span class="input-group-text bg-transparent border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <!-- Added id="inventorySearch" to enable the script to find it -->
            <input type="text" id="inventorySearch" class="form-control border-start-0 ps-0" placeholder="Search items...">
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById('inventorySearch');
        
        searchInput.addEventListener('keyup', function () {
            const searchTerm = this.value.toLowerCase();
            // Targets all table rows inside the tbody of your existing table
            const tableRows = document.querySelectorAll('table tbody tr');

            tableRows.forEach(row => {
                // This checks the text content of the row (Name, SKU, etc.)
                const text = row.textContent.toLowerCase();
                
                // If the search term is found, show the row; otherwise, hide it
                if (text.includes(searchTerm)) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        });
    });
</script>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr class="fw-bold">
                    <th class="ps-4">Item Name</th>
                    <th>Category</th>
                    <th>Quantity</th>
                    <th>Price</th>
                    <th>Status</th>
                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                    {
                        <th class="text-center">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-medium">@item.Name</div>
                            <small class="text-muted">SKU: @item.SKU</small>
                        </td>
                        <td class="text-muted">@(item.Category?.Name ?? "N/A")</td>
                        <td>
                            <span class="@(item.QuantityInStock <= item.MinimumStockLevel ? "text-danger fw-bold" : "")">
                                @item.QuantityInStock
                            </span>
                        </td>
                        <td>@item.UnitPrice.ToString("C", new System.Globalization.CultureInfo("en-PH"))</td>
                        <td>
                            @if (item.QuantityInStock <= 0)
                            {
                                <span class="badge bg-danger-subtle text-danger border px-3 py-2">Out of Stock</span>
                            }
                            else if (item.QuantityInStock <= item.MinimumStockLevel)
                            {
                                <span class="badge bg-warning-subtle text-warning border px-3 py-2">Low Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-success-subtle text-success border px-3 py-2">In Stock</span>
                            }
                        </td>
                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                        {
                            <td class="text-center">
                                <button class="btn btn-link text-primary p-1 me-2"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editItemModal-@item.ProductId">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form asp-action="DeleteProduct" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-link text-danger p-1" onclick="return confirm('Are you sure you want to delete this item?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        }
                    </tr>

                    <!-- Edit Item Modal for each product -->
                    <div class="modal fade" id="editItemModal-@item.ProductId" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content border-0 shadow">
                                <div class="modal-header">
                                    <h5 class="modal-title fw-bold">Edit Item</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <form asp-action="EditProduct" method="post">
                                    <input type="hidden" name="ProductId" value="@item.ProductId" />
                                    <div class="modal-body p-4">
                                        <div class="mb-3">
                                            <label class="form-label fw-medium">Item Name</label>
                                            <input type="text" name="Name" class="form-control" value="@item.Name" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-medium">SKU</label>
                                            <input type="text" name="SKU" class="form-control" value="@item.SKU" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-medium">Category</label>
                                            <select name="CategoryId" class="form-select">
                                                @foreach (var cat in Model.Categories)
                                                {
                                                    <!option value="@cat.CategoryId" @(cat.CategoryId == item.CategoryId ? "selected" : "")>@cat.Name</!option>
                                                }
                                            </select>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-medium">Quantity</label>
                                                <input type="number" name="QuantityInStock" class="form-control" value="@item.QuantityInStock" required>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-medium">Price (₱)</label>
                                                <input type="number" name="UnitPrice" step="0.01" class="form-control" value="@item.UnitPrice" required>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-medium">Min Stock</label>
                                                <input type="number" name="MinimumStockLevel" class="form-control" value="@item.MinimumStockLevel" required>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-medium">Max Stock</label>
                                                <input type="number" name="MaximumStockLevel" class="form-control" value="@item.MaximumStockLevel" required>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn text-white px-4" style="background-color:#1a335d;">Update Item</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="addItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Add New Item</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateProduct" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Item Name</label>
                        <input type="text" name="Name" class="form-control" placeholder="Enter item name" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">SKU</label>
                        <input type="text" name="SKU" class="form-control" placeholder="Enter SKU" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Category</label>
                        <select name="CategoryId" class="form-select">
                            <option selected disabled>Select a category</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.CategoryId">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Quantity</label>
                            <input type="number" name="QuantityInStock" class="form-control" placeholder="0" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Price (₱)</label>
                            <input type="number" name="UnitPrice" step="0.01" class="form-control" placeholder="0.00" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Min Stock</label>
                            <input type="number" name="MinimumStockLevel" class="form-control" value="5" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Max Stock</label>
                            <input type="number" name="MaximumStockLevel" class="form-control" value="50" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn text-white px-4" style="background-color:#1a335d;">Add Item</button>
                </div>
            </form>
        </div>
    </div>
</div>