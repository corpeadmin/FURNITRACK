@{
    ViewData["Title"] = "Inventory Management";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <h2 class="fw-bold mb-0">Inventory Management</h2>
        <p class="text-muted">Manage your furniture stock and pricing</p>
    </div>

    <button class="btn text-white px-4 py-2 fw-bold shadow-sm"
            style="background-color: #1a335d;"
            data-bs-toggle="modal"
            data-bs-target="#addItemModal">
        <i class="bi bi-plus-lg me-2"></i> Add Item
    </button>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <div class="input-group">
            <span class="input-group-text bg-transparent border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" class="form-control border-start-0 ps-0" placeholder="Search items...">
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr class="fw-bold">
                    <th class="ps-4">Item Name</th>
                    <th>Category</th>
                    <th>Quantity</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="ps-4 fw-medium">Office Chair - Executive</td>
                    <td class="text-muted">Office Furniture</td>
                    <td>15</td>
                    <td>₱4,250</td>
                    <td><span class="badge bg-success-subtle text-success border px-3 py-2">In Stock</span></td>
                    <td class="text-center">
                        <button class="btn btn-link text-primary p-1 me-2"
                                data-bs-toggle="modal"
                                data-bs-target="#editItemModal">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-link text-danger p-1"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="addItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Add New Item</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Item Name</label>
                        <input type="text" class="form-control" placeholder="Enter item name">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Category</label>
                        <select class="form-select">
                            <option selected disabled>Select a category</option>
                            <option>Office Furniture</option>
                            <option>Dining</option>
                            <option>Living Room</option>
                            <option>Storage</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Quantity</label>
                        <input type="number" class="form-control" placeholder="Enter quantity">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Price (₱)</label>
                        <input type="number" class="form-control" placeholder="Enter price">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                <button class="btn text-white px-4" style="background-color:#1a335d;">Add Item</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Edit Item</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Item Name</label>
                        <input type="text" class="form-control" value="Office Chair - Executive">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Category</label>
                        <select class="form-select">
                            <option>Office Furniture</option>
                            <option>Dining</option>
                            <option>Living Room</option>
                            <option>Storage</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Quantity</label>
                        <input type="number" class="form-control" value="15">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Price (₱)</label>
                        <input type="number" class="form-control" value="4250">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                <button class="btn text-white px-4" style="background-color:#1a335d;">Update Item</button>
            </div>
        </div>
    </div>
</div>