@model FURNITRACK.ViewModels.SalesViewModel
@{
    ViewData["Title"] = "Sales Management";
}

<div class="mb-4">
    <h2 class="fw-bold">Sales Management</h2>
    <p class="text-muted">Record sales and manage transactions</p>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 border-bottom-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0">Available Items</h5>
                <div class="input-group input-group-sm w-50">
                    <span class="input-group-text bg-transparent"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search products...">
                </div>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var item in Model.Products)
                    {
                        <div class="col-md-6">
                            <div class="card border shadow-none h-100 btn text-start p-0 overflow-hidden item-card @(item.QuantityInStock <= 0 ? "opacity-50" : "")"
                                 onclick="@(item.QuantityInStock > 0 ? $"addToCart({item.ProductId}, '{item.Name.Replace("'", "\\'")}', {item.UnitPrice}, {item.QuantityInStock})" : "")">
                                <div class="p-3">
                                    <h6 class="fw-bold mb-1">@item.Name</h6>
                                    <div class="d-flex justify-content-between align-items-end mt-2">
                                        <span class="text-primary fw-bold">@item.UnitPrice.ToString("C", new System.Globalization.CultureInfo("en-PH"))</span>
                                        <small class="@(item.QuantityInStock <= item.MinimumStockLevel ? "text-danger fw-bold" : "text-muted")">
                                            Stock: @item.QuantityInStock
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0"><i class="bi bi-cart3 me-2"></i>Current Sale</h5>
            </div>
            <div id="cart-container" class="card-body p-3" style="min-height: 200px; max-height: 400px; overflow-y: auto;">
                <p class="text-muted text-center mt-5">Cart is empty</p>
            </div>
            <div class="card-footer bg-white p-4 border-top-0">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Total:</h5>
                    <h3 class="fw-bold mb-0" style="color: #1a335d;" id="cart-total">₱0</h3>
                </div>
                <button id="record-sale-btn" class="btn btn-success w-100 py-2 fw-bold opacity-50" disabled onclick="recordSale()">Record Sale</button>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0">Sales History</h5>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Order #</th>
                            <th>Customer</th>
                            <th>Items</th>
                            <th>Total Amount</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody id="sales-history-body">
                        @foreach (var sale in Model.Sales)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@sale.OrderNumber</td>
                                <td>@sale.CustomerName</td>
                                <td>
                                    @foreach (var item in sale.SalesItems)
                                    {
                                        <div class="small">@(item.Product?.Name ?? "Product") (x@item.Quantity)</div>
                                    }
                                </td>
                                <td class="fw-bold text-success">@sale.TotalAmount.ToString("C", new System.Globalization.CultureInfo("en-PH"))</td>
                                <td>
                                    <span class="badge @(sale.Status == "Delivered" ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning") px-3">
                                        @sale.Status
                                    </span>
                                </td>
                                <td class="text-muted small">@sale.SalesDate.ToString("g")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    let cart = [];
    let saleCounter = 2; // Starting after existing dummy data

    function addToCart(id, name, price, stock) {
        const existingItem = cart.find(item => item.id === id);
        if (existingItem) {
            if (existingItem.quantity < stock) {
                existingItem.quantity++;
            } else {
                alert("Maximum stock reached!");
            }
        } else {
            cart.push({ id, name, price, quantity: 1, stock });
        }
        renderCart();
    }

    function updateQuantity(id, delta) {
        const item = cart.find(item => item.id === id);
        if (item) {
            const newQty = item.quantity + delta;
            if (newQty > 0 && newQty <= item.stock) {
                item.quantity = newQty;
            } else if (newQty === 0) {
                removeFromCart(id);
                return;
            }
        }
        renderCart();
    }

    function removeFromCart(id) {
        cart = cart.filter(item => item.id !== id);
        renderCart();
    }

    function renderCart() {
        const container = document.getElementById('cart-container');
        const totalDisplay = document.getElementById('cart-total');
        const recordBtn = document.getElementById('record-sale-btn');

        if (cart.length === 0) {
            container.innerHTML = '<p class="text-muted text-center mt-5">Cart is empty</p>';
            totalDisplay.innerText = '₱0';
            recordBtn.disabled = true;
            recordBtn.classList.add('opacity-50');
            return;
        }

        let total = 0;
        container.innerHTML = cart.map(item => {
            const itemTotal = item.price * item.quantity;
            total += itemTotal;
            return `
                <div class="card border p-3 mb-2 shadow-sm">
                    <div class="d-flex justify-content-between align-items-start">
                        <h6 class="fw-bold mb-1" style="font-size: 0.9rem;">${item.name}</h6>
                        <button class="btn btn-sm text-danger p-0" onclick="removeFromCart(${item.id})">🗑️</button>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <div class="btn-group btn-group-sm border">
                            <button class="btn btn-light" onclick="updateQuantity(${item.id}, -1)">-</button>
                            <span class="px-3 py-1 bg-white">${item.quantity}</span>
                            <button class="btn btn-light" onclick="updateQuantity(${item.id}, 1)">+</button>
                        </div>
                        <span class="fw-bold text-dark">₱${itemTotal.toLocaleString()}</span>
                    </div>
                </div>
            `;
        }).join('');

        totalDisplay.innerText = '₱' + total.toLocaleString();
        recordBtn.disabled = false;
        recordBtn.classList.remove('opacity-50');
    }

    async function recordSale() {
        if (cart.length === 0) return;

        const recordBtn = document.getElementById('record-sale-btn');
        recordBtn.disabled = true;
        recordBtn.innerText = 'Processing...';

        const saleData = {
            customerName: "Walk-in Customer", // Could be expanded to a form
            customerEmail: "walkin@example.com",
            items: cart.map(item => ({
                productId: item.id,
                quantity: item.quantity,
                price: item.price
            }))
        };

        try {
            const response = await fetch('/Home/RecordSale', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(saleData)
            });

            if (response.ok) {
                const result = await response.json();
                alert(`Sale recorded successfully! Order: ${result.orderNumber}`);
                location.reload(); // Reload to refresh history and stock levels
            } else {
                const error = await response.text();
                alert(`Error recording sale: ${error}`);
                recordBtn.disabled = false;
                recordBtn.innerText = 'Record Sale';
            }
        } catch (err) {
            console.error('Sale error:', err);
            alert('An unexpected error occurred.');
            recordBtn.disabled = false;
            recordBtn.innerText = 'Record Sale';
        }
    }
</script>

<style>
    .item-card {
        transition: all 0.2s ease;
        cursor: pointer;
    }

        .item-card:hover {
            border-color: #0d6efd !important;
            background-color: #f8f9ff;
            transform: translateY(-2px);
        }
</style>