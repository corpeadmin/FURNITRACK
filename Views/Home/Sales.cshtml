@{
    ViewData["Title"] = "Sales Management";
}

<div class="mb-4">
    <h2 class="fw-bold">Sales Management</h2>
    <p class="text-muted">Record sales and manage transactions</p>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 border-bottom-0">
                <h5 class="fw-bold mb-0">Available Items</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="card border shadow-none h-100 btn text-start p-0 overflow-hidden item-card"
                             onclick="addToCart(1, 'Office Chair - Executive', 4250, 15)">
                            <div class="p-3">
                                <h6 class="fw-bold mb-1">Office Chair - Executive</h6>
                                <div class="d-flex justify-content-between align-items-end mt-2">
                                    <span class="text-primary fw-bold">₱4,250</span>
                                    <small class="text-muted">Stock: 15</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border shadow-none h-100 btn text-start p-0 overflow-hidden item-card"
                             onclick="addToCart(2, 'Dining Table - Oak Wood', 12500, 8)">
                            <div class="p-3">
                                <h6 class="fw-bold mb-1">Dining Table - Oak Wood</h6>
                                <div class="d-flex justify-content-between align-items-end mt-2">
                                    <span class="text-primary fw-bold">₱12,500</span>
                                    <small class="text-muted">Stock: 8</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border shadow-none h-100 btn text-start p-0 overflow-hidden item-card"
                             onclick="addToCart(3, 'Bookshelf - 5-Tier', 3200, 3)">
                            <div class="p-3">
                                <h6 class="fw-bold mb-1">Bookshelf - 5-Tier</h6>
                                <div class="d-flex justify-content-between align-items-end mt-2">
                                    <span class="text-primary fw-bold">₱3,200</span>
                                    <small class="text-warning fw-bold">Stock: 3</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border shadow-none h-100 btn text-start p-0 overflow-hidden item-card"
                             onclick="addToCart(4, 'Coffee Table - Modern', 6750, 12)">
                            <div class="p-3">
                                <h6 class="fw-bold mb-1">Coffee Table - Modern</h6>
                                <div class="d-flex justify-content-between align-items-end mt-2">
                                    <span class="text-primary fw-bold">₱6,750</span>
                                    <small class="text-muted">Stock: 12</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0"><i class="bi bi-cart3 me-2"></i>Current Sale</h5>
            </div>
            <div id="cart-container" class="card-body p-3" style="min-height: 200px; max-height: 400px; overflow-y: auto;">
                <p class="text-muted text-center mt-5">Cart is empty</p>
            </div>
            <div class="card-footer bg-white p-4 border-top-0">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Total:</h5>
                    <h3 class="fw-bold mb-0" style="color: #1a335d;" id="cart-total">₱0</h3>
                </div>
                <button id="record-sale-btn" class="btn btn-success w-100 py-2 fw-bold opacity-50" disabled onclick="recordSale()">Record Sale</button>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0">Sales History</h5>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Sale ID</th>
                            <th>Items</th>
                            <th>Total Amount</th>
                            <th>Date & Time</th>
                        </tr>
                    </thead>
                    <tbody id="sales-history-body">
                        <tr>
                            <td class="ps-4 fw-bold">#0001</td>
                            <td>
                                <div class="small">Office Chair - Executive (x2)</div>
                                <div class="small text-muted">Desk Lamp - LED (x3)</div>
                            </td>
                            <td class="fw-bold text-success">₱11,170</td>
                            <td class="text-muted small">4/22/2026, 1:28:56 PM</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    let cart = [];
    let saleCounter = 2; // Starting after existing dummy data

    function addToCart(id, name, price, stock) {
        const existingItem = cart.find(item => item.id === id);
        if (existingItem) {
            if (existingItem.quantity < stock) {
                existingItem.quantity++;
            } else {
                alert("Maximum stock reached!");
            }
        } else {
            cart.push({ id, name, price, quantity: 1, stock });
        }
        renderCart();
    }

    function updateQuantity(id, delta) {
        const item = cart.find(item => item.id === id);
        if (item) {
            const newQty = item.quantity + delta;
            if (newQty > 0 && newQty <= item.stock) {
                item.quantity = newQty;
            } else if (newQty === 0) {
                removeFromCart(id);
                return;
            }
        }
        renderCart();
    }

    function removeFromCart(id) {
        cart = cart.filter(item => item.id !== id);
        renderCart();
    }

    function renderCart() {
        const container = document.getElementById('cart-container');
        const totalDisplay = document.getElementById('cart-total');
        const recordBtn = document.getElementById('record-sale-btn');

        if (cart.length === 0) {
            container.innerHTML = '<p class="text-muted text-center mt-5">Cart is empty</p>';
            totalDisplay.innerText = '₱0';
            recordBtn.disabled = true;
            recordBtn.classList.add('opacity-50');
            return;
        }

        let total = 0;
        container.innerHTML = cart.map(item => {
            const itemTotal = item.price * item.quantity;
            total += itemTotal;
            return `
                <div class="card border p-3 mb-2 shadow-sm">
                    <div class="d-flex justify-content-between align-items-start">
                        <h6 class="fw-bold mb-1" style="font-size: 0.9rem;">${item.name}</h6>
                        <button class="btn btn-sm text-danger p-0" onclick="removeFromCart(${item.id})">🗑️</button>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <div class="btn-group btn-group-sm border">
                            <button class="btn btn-light" onclick="updateQuantity(${item.id}, -1)">-</button>
                            <span class="px-3 py-1 bg-white">${item.quantity}</span>
                            <button class="btn btn-light" onclick="updateQuantity(${item.id}, 1)">+</button>
                        </div>
                        <span class="fw-bold text-dark">₱${itemTotal.toLocaleString()}</span>
                    </div>
                </div>
            `;
        }).join('');

        totalDisplay.innerText = '₱' + total.toLocaleString();
        recordBtn.disabled = false;
        recordBtn.classList.remove('opacity-50');
    }

    function recordSale() {
        const historyBody = document.getElementById('sales-history-body');
        const totalStr = document.getElementById('cart-total').innerText;
        const now = new Date().toLocaleString();

        // Build items string for history
        const itemsHtml = cart.map(item => `<div class="small">${item.name} (x${item.quantity})</div>`).join('');

        // Create new row
        const newRow = `
            <tr>
                <td class="ps-4 fw-bold">#${String(saleCounter++).padStart(4, '0')}</td>
                <td>${itemsHtml}</td>
                <td class="fw-bold text-success">${totalStr}</td>
                <td class="text-muted small">${now}</td>
            </tr>
        `;

        // Prepend to table (add to top)
        historyBody.insertAdjacentHTML('afterbegin', newRow);

        // Clear cart
        cart = [];
        renderCart();
        alert("Sale recorded!");
    }
</script>

<style>
    .item-card {
        transition: all 0.2s ease;
        cursor: pointer;
    }

        .item-card:hover {
            border-color: #0d6efd !important;
            background-color: #f8f9ff;
            transform: translateY(-2px);
        }
</style>