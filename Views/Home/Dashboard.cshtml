@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
    <h2 class="fw-bold">Dashboard</h2>
    <p class="text-muted">Welcome back! Here's your business overview.</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-1">Total Inventory Items</p>
                    <h3 class="fw-bold mb-0">247</h3>
                </div>
                <div class="rounded p-2" style="background-color: #1a335d;">
                    <i class="bi bi-box-seam text-white"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-1">Low Stock Alerts</p>
                    <h3 class="fw-bold mb-0">12</h3>
                </div>
                <div class="bg-danger rounded p-2">
                    <i class="bi bi-exclamation-triangle text-white"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-1">Today's Sales</p>
                    <h3 class="fw-bold mb-0">₱18,450</h3>
                </div>
                <div class="bg-success rounded p-2">
                    <i class="bi bi-currency-dollar text-white"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-1">Monthly Sales</p>
                    <h3 class="fw-bold mb-0">₱342,890</h3>
                </div>
                <div class="bg-warning rounded p-2">
                    <i class="bi bi-graph-up-arrow text-white"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-5">
    <div class="col-md-4">
        <a asp-controller="Home" asp-action="Inventory" class="btn text-white w-100 py-3 fw-bold shadow-sm d-flex align-items-center justify-content-center" style="background-color: #1a335d;">
            <i class="bi bi-plus-lg me-2"></i> Add Inventory Item
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Home" asp-action="Sales" class="btn btn-success w-100 py-3 fw-bold shadow-sm d-flex align-items-center justify-content-center">
            <i class="bi bi-cart-plus me-2"></i> Record Sale
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Home" asp-action="Reports" class="btn btn-white border w-100 py-3 fw-bold shadow-sm d-flex align-items-center justify-content-center bg-white">
            <i class="bi bi-bar-chart-line me-2"></i> View Reports
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3 border-0">
        <h5 class="fw-bold mb-0">Recent Activity</h5>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light text-muted">
                <tr>
                    <th>Type</th>
                    <th>Item</th>
                    <th>Quantity</th>
                    <th>Amount</th>
                    <th>Time</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><span class="badge bg-success-subtle text-success px-3">Sale</span></td>
                    <td>Office Chair - Executive</td>
                    <td>2</td>
                    <td>₱8,500</td>
                    <td class="text-muted">10 minutes ago</td>
                </tr>
                <tr>
                    <td><span class="badge bg-primary-subtle text-primary px-3">Restock</span></td>
                    <td>Wooden Dining Table</td>
                    <td>5</td>
                    <td>--</td>
                    <td class="text-muted">1 hour ago</td>
                </tr>
                <tr>
                    <td><span class="badge bg-success-subtle text-success px-3">Sale</span></td>
                    <td>Queen Bed Frame</td>
                    <td>1</td>
                    <td>₱12,000</td>
                    <td class="text-muted">3 hours ago</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>