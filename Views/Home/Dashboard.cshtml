@model FURNITRACK.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
    <h2 class="fw-bold">Dashboard</h2>
    <p class="text-muted">Welcome back! Here's your business overview.</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card glass-card widget-glow p-3 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted small mb-1">Total Inventory Items</p>
                    <h3 class="fw-bold mb-0 counter-value" data-target="@Model.TotalProducts">0</h3>
                </div>
                <div class="bg-primary bg-opacity-10 p-3 rounded-3">
                    <i class="bi bi-box-seam text-primary fs-4"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card glass-card widget-glow p-3 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted small mb-1">Low Stock Alerts</p>
                    <h3 class="fw-bold mb-0 text-danger counter-value" data-target="@Model.LowStockProducts">0</h3>
                </div>
                <div class="bg-danger bg-opacity-10 p-3 rounded-3">
                    <i class="bi bi-exclamation-triangle text-danger fs-4"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card glass-card widget-glow p-3 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted small mb-1">Monthly Revenue</p>
                    <h4 class="fw-bold mb-0">@Model.TotalSalesThisMonth.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</h4>
                </div>
                <div class="bg-success bg-opacity-10 p-3 rounded-3">
                    <i class="bi bi-cash-stack text-success fs-4"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card glass-card widget-glow p-3 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted small mb-1">Avg. Sale Value</p>
                    <h4 class="fw-bold mb-0">@Model.AverageSaleValue.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</h4>
                </div>
                <div class="bg-warning bg-opacity-10 p-3 rounded-3">
                    <i class="bi bi-graph-up-arrow text-warning fs-4"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-5">
    <div class="col-md-4">
        <a asp-controller="Home" asp-action="Inventory" class="btn btn-primary glass-card border-0 w-100 py-3 fw-bold shadow-sm d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #1a335d 0%, #0d1b31 100%) !important; color: white !important;">
            <i class="bi bi-plus-lg me-2"></i> Add Inventory Item
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Home" asp-action="Sales" class="btn btn-success glass-card border-0 w-100 py-3 fw-bold shadow-sm d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #198754 0%, #0f5132 100%) !important; color: white !important;">
            <i class="bi bi-cart-plus me-2"></i> Record Sale
        </a>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <div class="col-md-4">
            <a asp-controller="Home" asp-action="Reports" class="btn glass-card w-100 py-3 fw-bold shadow-sm d-flex align-items-center justify-content-center">
                <i class="bi bi-bar-chart-line me-2"></i> View Reports
            </a>
        </div>
    }
</div>

<div class="row g-4 mb-4">
    <div class="col-md-8">
        <div class="card glass-card h-100">
            <div class="card-header bg-transparent py-3 border-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0">Recent Sales</h5>
                <a asp-action="Sales" class="btn btn-sm btn-link text-decoration-none p-0">View All</a>
                </div>
                <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="text-muted">
                        <tr>
                            <th class="ps-4">Order #</th>
                            <th>Customer</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sale in Model.RecentSales)
                        {
                            <tr>
                                <td class="ps-4 fw-medium">@sale.OrderNumber</td>
                                <td>@sale.CustomerName</td>
                                <td class="fw-bold">@sale.TotalAmount.ToString("C", new System.Globalization.CultureInfo("en-PH"))</td>
                                <td>
                                    @switch (sale.Status)
                                    {
                                        case "Delivered":
                                            <span class="badge bg-success-subtle text-success px-3 py-2 border border-success border-opacity-25 rounded-pill">Delivered</span>
                                            break;
                                        case "Pending":
                                            <span class="badge bg-warning-subtle text-warning px-3 py-2 border border-warning border-opacity-25 rounded-pill">Pending</span>
                                            break;
                                        case "Cancelled":
                                            <span class="badge bg-danger-subtle text-danger px-3 py-2 border border-danger border-opacity-25 rounded-pill">Cancelled</span>
                                            break;
                                        default:
                                            <span class="badge bg-primary-subtle text-primary px-3 py-2 border border-primary border-opacity-25 rounded-pill">@sale.Status</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card glass-card h-100">
            <div class="card-header bg-transparent py-3 border-0">
                <h5 class="fw-bold mb-0 text-danger">Low Stock Alerts</h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush bg-transparent">
                    @foreach (var item in Model.LowStockItems)
                    {
                        <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center py-3 border-bottom border-white border-opacity-10">
                            <div>
                                <p class="mb-0 fw-medium">@item.Name</p>
                                <small class="text-muted">SKU: @item.SKU</small>
                            </div>
                            <div class="text-end">
                                <span class="badge stock-low rounded-pill px-3">@item.QuantityInStock Left</span>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const counters = document.querySelectorAll('.counter-value');
            const speed = 200;

            counters.forEach(counter => {
                const updateCount = () => {
                    const target = +counter.getAttribute('data-target');
                    const count = +counter.innerText;
                    const inc = target / speed;

                    if (count < target) {
                        counter.innerText = Math.ceil(count + inc);
                        setTimeout(updateCount, 1);
                    } else {
                        counter.innerText = target;
                    }
                };
                updateCount();
            });
        });
    </script>
}