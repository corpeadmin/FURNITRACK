@model FURNITRACK.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
    <h2 class="fw-bold">Dashboard</h2>
    <p class="text-muted">Welcome back! Here's your business overview.</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-1">Total Inventory Items</p>
                    <h3 class="fw-bold mb-0">@Model.TotalProducts</h3>
                </div>
                <div class="rounded p-2" style="background-color: #1a335d;">
                    <i class="bi bi-box-seam text-white"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-1">Low Stock Alerts</p>
                    <h3 class="fw-bold mb-0">@Model.LowStockProducts</h3>
                </div>
                <div class="bg-danger rounded p-2">
                    <i class="bi bi-exclamation-triangle text-white"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-1">Monthly Sales</p>
                    <h3 class="fw-bold mb-0">@Model.TotalSalesThisMonth.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</h3>
                </div>
                <div class="bg-success rounded p-2">
                    <i class="bi bi-currency-dollar text-white"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-1">Avg. Sale Value</p>
                    <h3 class="fw-bold mb-0">@Model.AverageSaleValue.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</h3>
                </div>
                <div class="bg-warning rounded p-2">
                    <i class="bi bi-graph-up-arrow text-white"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-5">
    <div class="col-md-4">
        <a asp-controller="Home" asp-action="Inventory" class="btn text-white w-100 py-3 fw-bold shadow-sm d-flex align-items-center justify-content-center" style="background-color: #1a335d;">
            <i class="bi bi-plus-lg me-2"></i> Add Inventory Item
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Home" asp-action="Sales" class="btn btn-success w-100 py-3 fw-bold shadow-sm d-flex align-items-center justify-content-center">
            <i class="bi bi-cart-plus me-2"></i> Record Sale
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Home" asp-action="Reports" class="btn btn-white border w-100 py-3 fw-bold shadow-sm d-flex align-items-center justify-content-center bg-white">
            <i class="bi bi-bar-chart-line me-2"></i> View Reports
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0">Recent Sales</h5>
                <a asp-action="Sales" class="btn btn-sm btn-link text-decoration-none p-0">View All</a>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light text-muted">
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sale in Model.RecentSales)
                        {
                            <tr>
                                <td class="fw-medium">@sale.OrderNumber</td>
                                <td>@sale.CustomerName</td>
                                <td class="fw-bold">@sale.TotalAmount.ToString("C", new System.Globalization.CultureInfo("en-PH"))</td>
                                <td>
                                    @switch (sale.Status)
                                    {
                                        case "Delivered":
                                            <span class="badge bg-success-subtle text-success px-3">Delivered</span>
                                            break;
                                        case "Pending":
                                            <span class="badge bg-warning-subtle text-warning px-3">Pending</span>
                                            break;
                                        case "Cancelled":
                                            <span class="badge bg-danger-subtle text-danger px-3">Cancelled</span>
                                            break;
                                        default:
                                            <span class="badge bg-primary-subtle text-primary px-3">@sale.Status</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 border-0">
                <h5 class="fw-bold mb-0 text-danger">Low Stock Alerts</h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var item in Model.LowStockItems)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <div>
                                <p class="mb-0 fw-medium">@item.Name</p>
                                <small class="text-muted">SKU: @item.SKU</small>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-danger rounded-pill">@item.QuantityInStock Left</span>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>