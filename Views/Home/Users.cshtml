@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid py-4">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h2 class="h3 fw-bold text-dark mb-1">User Management</h2>
            <p class="text-secondary small mb-0">Manage employee accounts and permissions</p>
        </div>
        <div class="col-auto">
            <button type="button" class="btn btn-primary d-flex align-items-center gap-2"
                    style="background-color: #1a2b4b; border: none;"
                    data-bs-toggle="modal" data-bs-target="#addUserModal">
                <i class="bi bi-person-plus"></i> Add User
            </button>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="card-title mb-0">User Accounts</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-secondary small text-uppercase">
                            <tr>
                                <th class="ps-4">Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Last Login</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-placeholder me-3"><i class="bi bi-person"></i></div>
                                        <span class="fw-medium">Maria Santos</span>
                                    </div>
                                </td>
                                <td>maria@kensmarketing.com</td>
                                <td><span class="badge rounded-pill bg-light text-dark border px-3">Staff</span></td>
                                <td><span class="text-success fw-bold">Active</span></td>
                                <td class="text-muted small">2026-04-21<br />09:15</td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-link btn-sm text-primary p-0 me-2"
                                            data-bs-toggle="modal" data-bs-target="#editUserModal">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="btn btn-link btn-sm text-danger p-0"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h6 class="fw-bold d-flex align-items-center mb-3">
                        <i class="bi bi-shield-check text-primary me-2"></i> Owner Permissions
                    </h6>
                    <ul class="list-unstyled mb-0">
                        <li class="small mb-2"><i class="bi bi-check2 text-success me-2"></i> Full system access</li>
                        <li class="small mb-2"><i class="bi bi-check2 text-success me-2"></i> Manage users</li>
                        <li class="small mb-2"><i class="bi bi-check2 text-success me-2"></i> View all reports</li>
                        <li class="small mb-2"><i class="bi bi-check2 text-success me-2"></i> Manage inventory</li>
                        <li class="small mb-2"><i class="bi bi-check2 text-success me-2"></i> Process sales</li>
                        <li class="small"><i class="bi bi-check2 text-success me-2"></i> Configure settings</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Add New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-4">
                <form>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Full Name</label>
                        <input type="text" class="form-control form-control-lg fs-6" placeholder="">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Email Address</label>
                        <input type="email" class="form-control form-control-lg fs-6" placeholder="">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Role</label>
                        <select class="form-select form-control-lg fs-6">
                            <option selected>Staff</option>
                            <option>Owner</option>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold small">Password</label>
                        <input type="password" class="form-control form-control-lg fs-6" placeholder="Minimum 8 characters">
                    </div>
                    <div class="row g-2">
                        <div class="col">
                            <button type="button" class="btn btn-light w-100 py-2" data-bs-dismiss="modal" style="background-color: #f0efeb;">Cancel</button>
                        </div>
                        <div class="col">
                            <button type="submit" class="btn btn-primary w-100 py-2" style="background-color: #1a2b4b;">Add User</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Edit User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-4">
                <form>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Full Name</label>
                        <input type="text" class="form-control form-control-lg fs-6" value="Maria Santos">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Email Address</label>
                        <input type="email" class="form-control form-control-lg fs-6" value="maria@kensmarketing.com">
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold small">Role</label>
                        <select class="form-select form-control-lg fs-6">
                            <option selected>Staff</option>
                            <option>Owner</option>
                        </select>
                    </div>
                    <div class="row g-2">
                        <div class="col">
                            <button type="button" class="btn btn-light w-100 py-2" data-bs-dismiss="modal" style="background-color: #f0efeb;">Cancel</button>
                        </div>
                        <div class="col">
                            <button type="submit" class="btn btn-primary w-100 py-2" style="background-color: #1a2b4b;">Update User</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* ... Keep previous styles ... */
    .form-control, .form-select {
        border-color: #dee2e6;
    }

        .form-control:focus, .form-select:focus {
            border-color: #1a2b4b;
            box-shadow: none;
        }

    .modal-content {
        border-radius: 12px;
    }
</style>