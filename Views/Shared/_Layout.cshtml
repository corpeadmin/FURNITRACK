<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FURNITRACK</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @{
        // Check if we are on the Index page to hide the sidebar
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
        bool isIndexPage = currentAction == "Index";
    }

    @if (isIndexPage)
    {
        @* SIDEBAR HIDDEN FOR INDEX.CSHTML *@
        <main role="main">
            @RenderBody()
        </main>
    }
    else
    {
        @* SIDEBAR VISIBLE FOR ALL OTHER PAGES *@
        <div class="d-flex" id="wrapper">
            <!-- FIXED SIDEBAR - Won't scroll with page -->
            <div class="bg-dark-blue text-white position-fixed"
                 id="sidebar-wrapper"
                 style="min-width: 250px; min-height: 100vh; background-color: #1a335d; top: 0; left: 0; z-index: 1000;">
                <div class="sidebar-heading p-4">
                    <h4 class="fw-bold mb-0">FURNITRACK</h4>
                    <small class="text-white-50">Furniture Inventory Management</small>
                </div>

                <div class="list-group list-group-flush px-3">
                    @* Working Redirects *@
                    <a asp-controller="Home" asp-action="Dashboard" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-2 rounded mb-1 @(currentAction == "Dashboard" ? "active-link" : "")">
                        <i class="bi bi-grid-1x2-fill me-2"></i> Dashboard
                    </a>
                    <a asp-controller="Home" asp-action="Inventory" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-2 rounded mb-1 @(currentAction == "Inventory" ? "active-link" : "")">
                        <i class="bi bi-box-seam me-2"></i> Inventory
                    </a>
                    <a asp-controller="Home" asp-action="Sales" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-2 rounded mb-1 @(currentAction == "Sales" ? "active-link" : "")">
                        <i class="bi bi-cart me-2"></i> Sales
                    </a>
                    <a asp-controller="Home" asp-action="Reports" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-2 rounded mb-1 @(currentAction == "Reports" ? "active-link" : "")">
                        <i class="bi bi-bar-chart-line me-2"></i> Reports
                    </a>
                    <a asp-controller="Home" asp-action="Users" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-2 rounded mb-1 @(currentAction == "Users" ? "active-link" : "")">
                        <i class="bi bi-people me-2"></i> Users
                    </a>

                    <div class="mt-5 pt-5">
                        @* Logout: Static button, no function *@
                        <a href="#" class="list-group-item list-group-item-action bg-transparent text-white border-0 py-2">
                            <i class="bi bi-box-arrow-left me-2"></i> Logout
                        </a>
                    </div>
                </div>
            </div>

            <!-- PAGE CONTENT - Offset to prevent overlap with fixed sidebar -->
            <div id="page-content-wrapper" class="w-100 bg-light" style="margin-left: 250px;">
                <div class="container-fluid p-4">
                    <main role="main">
                        @RenderBody()
                    </main>
                </div>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    </script>
</body>
</html>